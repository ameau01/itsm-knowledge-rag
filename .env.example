# Template for .env. Copy to `.env` and fill in real values.
# .env is gitignored; .env.example is committed.

# ============================================================
# Mode
# ============================================================
# mock  - replay recorded fixtures through the real pipeline.
#         No LLM, no API key. Used by `docker compose up demo`.
# live  - real model calls. Requires ANTHROPIC_API_KEY.
PIPELINE_MODE=mock

# ============================================================
# Hugging Face dataset cache
# ============================================================
# The published corpus (ameau01/synthetic-it-support-tickets) is
# fetched on first run and cached here. Relative paths resolve to
# the project root. Reset with `rm -rf .hf_cache`.
HF_HOME=.hf_cache

# ============================================================
# Qdrant (hybrid index: dense + sparse vectors, native fusion)
# ============================================================
# Docker compose provides this service; the default below matches
# the compose file. For local dev (Path C), run your own Qdrant
# (docker run -p 6333:6333 qdrant/qdrant) or point at a remote one.
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=          # only for authenticated/remote instances
QDRANT_COLLECTION=itsm_tickets

# ============================================================
# Anthropic (curation + judge)
# ============================================================
# Required for live mode and for the judge-based eval axes.
# When unset, judge-based axes report "skipped"; the deterministic
# axes (leakage, retention) still run.
# ANTHROPIC_API_KEY=sk-ant-...

# Curation model writes the per-family overview during ingest.
# Judge model grades faithfulness/citation and must differ from
# the curation model (see docs/evaluation.md).
CURATION_MODEL=claude-haiku-4-5-20251001
JUDGE_MODEL=  # must differ from CURATION_MODEL; decision pending

# ============================================================
# Embeddings (dense half of hybrid retrieval)
# ============================================================
# Decision pending (see docs/decisions.md). Default assumes a
# local sentence-transformers model, which keeps mock mode
# offline and needs no extra key.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================
# Serving
# ============================================================
# Ports for the two surfaces (support search view, employee wiki).
SUPPORT_VIEW_PORT=8000
EMPLOYEE_VIEW_PORT=8001
