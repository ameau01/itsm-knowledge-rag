# Template for .env. Copy to `.env` and fill in real values.
# .env is gitignored; .env.example is committed.

# ============================================================
# Mode
# ============================================================
# mock  - replay recorded fixtures through the real pipeline.
#         No LLM, no API key. Used by `docker compose up demo`.
# live  - real model calls. Requires ANTHROPIC_API_KEY.
PIPELINE_MODE=mock

# ============================================================
# Hugging Face dataset cache
# ============================================================
# The published corpus (ameau01/synthetic-it-support-tickets)
HF_HOME=.hf_cache

# ============================================================
# Operational data store (SQLite)
# ============================================================
OPERATIONAL_STORE=.operational_store

# ============================================================
# Vector Database
# ============================================================
# Where the vector database runs:
#   QDRANT_LOCAL=true  (default) — EMBEDDED, in-process, on disk at LOCAL_VECTOR_DB_PATH.
#   QDRANT_LOCAL=false           — connect to a Qdrant SERVER at QDRANT_URL. Server can be local container or on cloud.
VECTOR_DB_PROVIDER=qdrant
QDRANT_LOCAL=true
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=itsm_tickets
# QDRANT_API_KEY=          # only for a remote / Qdrant Cloud instance
EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-l-v2.0
EMBEDDING_DIM=1024                 # Arctic -l-v2.0 (8192-token context)
SPARSE_MODEL=Qdrant/bm25           # BM25 sparse vectors via fastembed
ABSTENTION_PERCENTILE=5.0          # floor at the 5th percentile of in-corpus dense cosine scores


# ============================================================
# Anthropic (curation + judge)
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-...

# Curation model writes the per-family overview during ingest (Anthropic).
CURATION_MODEL=claude-haiku-4-5-20251001

# ============================================================
# OpenAI (DeepEval judge)
# ============================================================
# The retrieval/curation judge runs on an OpenAI frontier model
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-5.4
DEEPEVAL_TELEMETRY_OPT_OUT=YES


# ============================================================
# UI Streamlit And Mkdocs Serving
# ============================================================
# Default port for the search or wiki app. run_streamlit.sh and run_demo.sh use this when --port
# is omitted; a --port flag overrides it.
SUPPORT_VIEW_PORT=8000
WIKI_VIEW_PORT=8001
