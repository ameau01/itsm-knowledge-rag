# --- Internal-only workspace (never push) ---
.workspace/
INTERNAL_*

# --- HuggingFace dataset cache (downloaded at runtime, not source) ---
# Reset with `rm -rf .hf_cache`.
.hf_cache/

# --- Operational data store (SQLite, populated at runtime, not source) ---
# Reset with `rm -rf .operational_store`.
.operational_store/

# --- Secrets and environment ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info/
*.egg
MANIFEST
.ruff_cache/
.uv-cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- Testing and coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# --- Notebooks ---
.ipynb_checkpoints/

# --- IDE and editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Generated artifacts (not source) ---
data/wiki/
data/generated/
eval/results/
reports/runs/

# --- Qdrant / docker volumes ---
qdrant_storage/
qdrant_data/

# --- Logs ---
*.log
logs/
evaluation-experiment/

# --- DeepEval (telemetry + caches, created at import time; not source) ---
# The folder name `.deepeval` is hardcoded in deepeval (constants.HIDDEN_DIR) and the
# folder is created when deepeval is first imported, so it cannot be renamed via config.
.deepeval/
.deepeval-cache.json
.deepeval-prompt-cache.json
